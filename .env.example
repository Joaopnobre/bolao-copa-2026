# ============================================
# Bolão Copa do Mundo 2026 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================

# --- BANCO DE DADOS ---
# Desenvolvimento local (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# Produção (PostgreSQL / Neon):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# --- NEXTAUTH ---
# Gere um secret seguro: openssl rand -base64 32
NEXTAUTH_SECRET="troque-por-um-valor-secreto-e-longo"
NEXTAUTH_URL="http://localhost:3000"
# Em produção, mude NEXTAUTH_URL para a URL do seu site:
# NEXTAUTH_URL="https://seu-bolao.vercel.app"
