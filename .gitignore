# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NUNCA commitar .env com credenciais reais
.env
.env.local
.env.production
# Estes arquivos de exemplo SÃO commitados (sem segredos):
# .env.example → pode commitar
# .env.sqlite  → pode commitar
# .env.postgresql → NÃO commitar (tem credenciais)
.env.postgresql

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# SQLite — banco de dados local (nunca versionar)
prisma/dev.db
prisma/dev.db-shm
prisma/dev.db-wal
prisma/*.db
